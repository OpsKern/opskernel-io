---
const shipped = [
  'Governance cockpit — live session stream + real-time policy decisions',
  'Visual policy editor — local rule builder, git-versioned',
  'Pre-send blocking — stops the request before it leaves the machine',
  'Hash-chained audit log — tamper-evident, exportable, provable',
  'Cost attribution + budget caps',
  'Shadow-AI scanning — detect unapproved tools',
  'DSAR + right-to-erase (tombstone + legal hold)',
  'Multi-tool capture: Claude Code, Cursor, Gemini CLI, Codex CLI, Aider, Ollama',
];

const inProgress = [
  'Knowledge API — query session history by actor, session, and content',
  'Auto-update via Tauri updater — background updates, no manual reinstall',
  'Windows code-signing (currently unsigned CI-verified build)',
];

const planned = [
  'Homebrew tap — brew install opskernel-io/tap/hookd',
  'Team Server — shared policy + central audit log for teams (BSL 1.1)',
  'Customer feedback pipeline — in-app feedback from the cockpit',
  'In-app release notes + changelog surface',
];
---

<section class="w-full px-6 md:px-12 lg:px-16 py-section">
  <div class="max-w-prose mx-auto">
    <h1 class="font-display font-bold text-4xl mb-4 tracking-tight">Roadmap</h1>
    <p class="text-ink-muted text-xl mb-2 max-w-narrow">
      Where hookd has been and where it's going.
    </p>
    <p class="font-mono text-xs text-ink-subtle mb-12">Direction only — no dates or commitments.</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Shipped -->
      <div>
        <h2 class="font-display font-semibold text-lg mb-4 text-accent tracking-tight">Shipped</h2>
        <ul class="space-y-3">
          {
            shipped.map((item) => (
              <li class="flex gap-2 text-sm text-ink-muted">
                <span class="text-accent mt-0.5 shrink-0" aria-hidden="true">
                  ✓
                </span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- In Progress -->
      <div>
        <h2 class="font-display font-semibold text-lg mb-4 text-ink tracking-tight">In progress</h2>
        <ul class="space-y-3">
          {
            inProgress.map((item) => (
              <li class="flex gap-2 text-sm text-ink-muted">
                <span class="text-ink-subtle mt-0.5 shrink-0" aria-hidden="true">
                  ◐
                </span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- In the Pipeline -->
      <div>
        <h2 class="font-display font-semibold text-lg mb-4 text-ink-subtle tracking-tight">
          In the pipeline
        </h2>
        <ul class="space-y-3">
          {
            planned.map((item) => (
              <li class="flex gap-2 text-sm text-ink-subtle">
                <span class="mt-0.5 shrink-0" aria-hidden="true">
                  ○
                </span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="mt-12 pt-8 border-t border-ink-subtle/20 flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between"
    >
      <p class="text-ink-subtle text-sm">
        Want to influence the order?{' '}
        <a href="#waitlist" class="text-accent underline">Join the waitlist</a> — beta users shape what
        ships next.
      </p>
      <a href="/" class="font-mono text-xs text-ink-subtle hover:text-accent transition-colors">
        ← hookd home
      </a>
    </div>
  </div>
</section>
