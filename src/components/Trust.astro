---
const pillars = [
  {
    stat: 'Apache 2.0',
    label: 'Open source',
    sub: 'Read every line. The desktop tier is fully open.',
  },
  {
    stat: 'OS-level',
    label: 'Pre-send hook',
    sub: 'Kills the request before it hits the network — not after.',
  },
  {
    stat: 'Zero egress',
    label: 'Local-first',
    sub: 'Captured content never leaves your machine by default.',
  },
  {
    stat: 'No SDK',
    label: 'Drop-in',
    sub: 'No code changes. Install and it works.',
  },
];
---

<section class="w-full border-y border-ink-subtle/20 bg-surface-sunken">
  <div class="max-w-prose mx-auto px-6 md:px-12 lg:px-16 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {
        pillars.map(({ stat, label, sub }) => (
          <div class="space-y-1">
            <p class="font-display font-bold text-2xl text-accent">{stat}</p>
            <p class="font-medium text-ink text-sm">{label}</p>
            <p class="text-ink-subtle text-xs leading-relaxed">{sub}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
