---
import Base from '~/layouts/Base.astro';
import Nav from '~/components/Nav.astro';
import RoadmapSection from '~/components/Roadmap.astro';
import WaitlistForm from '~/components/WaitlistForm.astro';
---

<Base
  title="Roadmap — hookd"
  description="What hookd has shipped, what's in progress, and what's coming next."
>
  <Nav />
  <main>
    <RoadmapSection />
    <section
      id="waitlist"
      class="w-full px-6 md:px-12 lg:px-16 py-section border-t border-ink-subtle/10"
    >
      <div class="max-w-narrow mx-auto text-center space-y-4">
        <h2 class="font-display font-semibold text-2xl tracking-tight">Get early access</h2>
        <p class="text-ink-muted">Beta access rolls out from the waitlist before public launch.</p>
        <WaitlistForm variant="footer" />
      </div>
    </section>
  </main>
</Base>
