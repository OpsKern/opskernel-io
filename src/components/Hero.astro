---

---

<section class="w-full min-h-[60vh] flex flex-col justify-center px-6 md:px-12 lg:px-16 py-section">
  <div class="max-w-prose">
    <p class="font-mono text-sm text-ink-muted mb-6 tracking-wide">
      aiconsole <span class="text-accent">●</span> local-first AI governance
    </p>

    <h1 class="font-display font-bold text-4xl md:text-5xl leading-tight tracking-tight mb-6">
      Stop AI from leaking your code<br />
      <span class="text-ink-muted">before you hit send.</span>
    </h1>

    <p class="text-2xl text-ink-muted mb-10 max-w-narrow">
      Local-first governance for Claude Code, Cursor, and every LLM that sees your repo. Native OS
      hooks. No SDK. No cloud.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 mb-12">
      <a
        href="#waitlist"
        class="inline-flex items-center justify-center bg-accent text-surface font-medium px-6 py-3 rounded-md hover:bg-accent-hover active:bg-accent-press transition-colors"
      >
        Join waitlist →
      </a>
      <a
        href="https://github.com/OpsKern/aiconsole-core"
        class="inline-flex items-center justify-center bg-transparent text-accent font-medium px-6 py-3 rounded-md border border-accent hover:bg-accent/10 transition-colors"
      >
        View on GitHub ↗
      </a>
    </div>

    {/* Block-flow diagram — SVG placeholder until demo GIF lands (Phase B.3.1) */}
    <figure class="mt-8">
      <svg
        viewBox="0 0 560 80"
        role="img"
        aria-label="Prompt flows through aiconsole: redact or block before it reaches the LLM"
        class="w-full h-auto text-ink"
      >
        <defs>
          <style>
            .node {
              fill: #1a1a1a;
              stroke: currentColor;
              stroke-width: 1.25;
            }
            .label {
              font-family: Poppins, Inter, sans-serif;
              font-size: 13px;
              fill: currentColor;
            }
            .sub {
              font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
              font-size: 10px;
              fill: #8b8b8b;
            }
            .arrow {
              stroke: currentColor;
              stroke-width: 1.25;
              fill: none;
            }
            .accent {
              fill: #fbbf26;
            }
          </style>
        </defs>
        <rect class="node" x="4" y="22" width="108" height="36" rx="4"></rect>
        <text class="label" x="58" y="38" text-anchor="middle">prompt</text>
        <text class="sub" x="58" y="52" text-anchor="middle">Claude/GPT/…</text>

        <line class="arrow" x1="112" y1="40" x2="152" y2="40"></line>
        <polygon class="arrow" points="146,36 156,40 146,44"></polygon>

        <rect class="node" x="156" y="22" width="108" height="36" rx="4"></rect>
        <text class="label" x="210" y="38" text-anchor="middle">aiconsole</text>
        <text class="sub" x="210" y="52" text-anchor="middle">classify · redact</text>

        <line class="arrow" x1="264" y1="40" x2="304" y2="40"></line>
        <polygon class="arrow" points="298,36 308,40 298,44"></polygon>

        <rect class="node" x="308" y="22" width="108" height="36" rx="4"></rect>
        <text class="label accent" x="362" y="38" text-anchor="middle">decide</text>
        <text class="sub" x="362" y="52" text-anchor="middle">allow · block</text>

        <line class="arrow" x1="416" y1="40" x2="456" y2="40"></line>
        <polygon class="arrow" points="450,36 460,40 450,44"></polygon>

        <rect class="node" x="460" y="22" width="96" height="36" rx="4"></rect>
        <text class="label" x="508" y="38" text-anchor="middle">LLM / log</text>
        <text class="sub" x="508" y="52" text-anchor="middle">audit trail</text>
      </svg>
      <figcaption class="sr-only">
        aiconsole sits between your prompt and the LLM. It classifies, redacts, and then allows or
        blocks the send — with a hash-chained audit trail.
      </figcaption>
    </figure>
  </div>
</section>
