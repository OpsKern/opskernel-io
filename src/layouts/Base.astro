---
import '~/styles/brand.css';

export interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = 'hookd — stop AI from leaking your code before you hit send',
  description = 'Local-first governance for Claude Code, Cursor, and every LLM that sees your repo.',
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://opskernel.io').toString();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://opskernel.io/og.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://opskernel.io/og.svg" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Poppins — canonical body font per brandbook p.17. Preconnect first to cut TTFB. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Poppins:wght@400;500;600;700&display=swap"
    />

    <slot name="head" />
  </head>
  <body class="bg-surface text-ink antialiased min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus-visible:not-sr-only focus-visible:fixed focus-visible:top-4 focus-visible:left-4 focus-visible:z-50 focus-visible:bg-accent focus-visible:text-surface focus-visible:px-4 focus-visible:py-2 focus-visible:rounded-md focus-visible:font-medium"
    >
      Skip to main content
    </a>
    <slot />
  </body>
</html>
