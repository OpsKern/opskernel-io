---
import Base from '~/layouts/Base.astro';
---

<Base
  title="Check your inbox — hookd"
  description="Almost there — confirm your email to join the hookd waitlist."
>
  <main id="main" class="w-full px-6 md:px-12 lg:px-16 py-section">
    <div class="max-w-prose mx-auto text-center space-y-6">
      <p class="font-mono text-sm text-ink-muted tracking-wide">hookd · from OpsKern</p>

      <h1 class="font-display font-bold text-4xl tracking-tight text-ink">Check your inbox</h1>

      <p class="text-ink-muted text-lg">
        We sent a confirmation link to your email address. Click it to secure your spot on the
        waitlist.
      </p>

      <p class="text-ink-subtle text-sm">
        No email? Check your spam folder, or
        <a href="mailto:hello@opskernel.io" class="text-accent underline">contact us</a>.
      </p>

      <p class="font-mono text-xs text-ink-subtle tracking-wide pt-6">
        <a href="/" class="hover:text-accent">← hookd home</a>
      </p>
    </div>
  </main>
</Base>
