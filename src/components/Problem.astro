---
const pains = [
  {
    label: 'Your .env is in that prompt.',
    body: "Cursor sends your full file context. Claude Code sends your repo. The API key three lines above the function you're asking about goes with it.",
  },
  {
    label: 'You told it not to. It forgot anyway.',
    body: "Custom instructions and AI memory are advisory. Under context pressure or across sessions, the model deviates from its own rules. Governance that lives inside the model isn't governance.",
  },
  {
    label: 'Compliance needs a log. "Trust me" is not a log.',
    body: 'SOC 2, HIPAA, and GDPR auditors want a tamper-evident record of what AI saw. SaaS LLM vendors do not give you one.',
  },
];
---

<section class="w-full px-6 md:px-12 lg:px-16 py-section">
  <div class="max-w-prose mx-auto">
    <h2 class="font-display font-semibold text-4xl mb-4 tracking-tight">
      You know this is happening.
    </h2>
    <p class="text-ink-muted text-xl mb-10 max-w-narrow">
      Every prompt is a file read. Most engineers just haven't looked at what rides along.
    </p>
    <ul class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        pains.map(({ label, body }) => (
          <li class="space-y-3">
            <div
              class="h-8 w-8 rounded-md bg-accent/15 text-accent flex items-center justify-center font-mono text-sm"
              aria-hidden="true"
            >
              ●
            </div>
            <h3 class="font-medium text-ink text-lg">{label}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
