---
const steps = [
  {
    label: 'Capture',
    sub: 'native OS hooks',
    body: 'Every prompt is intercepted at the OS level before it reaches the network. No SDK to install, no browser extension, no proxy server.',
  },
  {
    label: 'Redact',
    sub: 'local classifier',
    body: 'A local rule set flags secrets, code fragments, and regulated identifiers. Rules live in your repo — versioned, reviewed, auditable.',
  },
  {
    label: 'Govern',
    sub: 'allow · block · query',
    body: 'Every outcome — allow, redact, block — lands in the cockpit in real time and is written to the hash-chained log. Query the full history with the Knowledge API.',
  },
];
---

<section class="w-full px-6 md:px-12 lg:px-16 py-section bg-surface-sunken">
  <div class="max-w-prose mx-auto">
    <h2 class="font-display font-semibold text-4xl mb-4 tracking-tight">How it works</h2>
    <p class="text-ink-muted text-2xl mb-12 max-w-narrow">
      Native OS hooks. No SDK. No cloud. Works with any LLM your team talks to.
    </p>

    <ol class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        steps.map(({ label, sub, body }, i) => (
          <li class="space-y-3 relative">
            <div class="flex items-baseline gap-3">
              <span class="font-mono text-accent text-sm" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="font-medium text-ink text-lg">{label}</h3>
            </div>
            <p class="font-mono text-ink-subtle text-xs uppercase tracking-widest">{sub}</p>
            <p class="text-ink-muted">{body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
