---
import WaitlistForm from './WaitlistForm.astro';
---

<section id="waitlist" class="w-full px-6 md:px-12 lg:px-16 py-section">
  <div class="max-w-prose mx-auto">
    <h2 class="font-display font-semibold text-4xl mb-4 tracking-tight">
      Ship with the governance in place.
    </h2>
    <p class="text-ink-muted text-2xl mb-10 max-w-narrow">
      Join the waitlist. Early builds ship before the public launch.
    </p>
    <WaitlistForm />
  </div>
</section>

<footer class="w-full border-t border-ink-subtle/20 bg-surface-sunken">
  <div class="max-w-prose mx-auto px-6 md:px-12 lg:px-16 py-12 space-y-8">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">
      <div>
        <p class="font-display text-xl text-ink">hookd</p>
        <p class="font-mono text-sm text-ink-muted mt-2">
          from <a href="https://opskern.com" class="hover:text-accent">OpsKern</a>
        </p>
      </div>

      <nav aria-label="Footer">
        <ul class="grid grid-cols-2 gap-x-8 gap-y-2 text-sm text-ink-muted">
          <li>
            <a href="https://github.com/OpsKern/hookd" class="hover:text-accent">GitHub</a>
          </li>
          <li><a href="/faq" class="hover:text-accent">FAQ</a></li>
          <li><a href="/privacy" class="hover:text-accent">Privacy</a></li>
          <li><a href="/terms" class="hover:text-accent">Terms</a></li>
        </ul>
      </nav>
    </div>

    <p class="font-mono text-xs text-ink-subtle tracking-wide">
      © 2026 operated by Will Smith. hookd and OpsKern are product and company marks. Apache 2.0 ·
      local-first · no SDK required · vendor-neutral.
    </p>
  </div>
</footer>
