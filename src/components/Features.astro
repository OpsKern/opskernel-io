---
const primaryFeatures = [
  {
    label: 'Governance cockpit',
    body: 'Live stream of every AI session. Intercept events, policy decisions, and cost ticks in real time — in a native desktop app. No log tailing.',
  },
  {
    label: 'Visual policy editor',
    body: 'Build redaction rules and block policies in a local GUI. Rules live in your repo — versioned, reviewed, auditable. No YAML required.',
  },
  {
    label: 'Cost attribution + budget caps',
    body: 'Track spend per session, actor, and project. Set hard limits before they blow up.',
  },
];

const secondaryFeatures = [
  {
    label: 'Shadow-AI scanning',
    body: 'Detects AI tools running on your machine that you did not configure hookd to watch. Know your full exposure surface.',
  },
  {
    label: 'DSAR + right-to-erase',
    body: 'Tamper-evident audit answers GDPR access requests. Legal-hold flag. Tombstone entries on demand.',
  },
  {
    label: 'Knowledge API (preview)',
    body: 'Query your session history. Full-text search over what was sent, blocked, or redacted.',
  },
];
---

<section class="w-full px-6 md:px-12 lg:px-16 py-section">
  <div class="max-w-prose mx-auto">
    <h2 class="font-display font-semibold text-4xl mb-12 tracking-tight">What it does</h2>
    <ul class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      {
        primaryFeatures.map(({ label, body }) => (
          <li class="bg-surface-raised rounded-lg p-6 space-y-2">
            <h3 class="font-medium text-ink text-lg">{label}</h3>
            <p class="text-ink-muted">{body}</p>
          </li>
        ))
      }
    </ul>
    <ul class="grid grid-cols-1 sm:grid-cols-3 gap-6 border-t border-ink-subtle/20 pt-8">
      {
        secondaryFeatures.map(({ label, body }) => (
          <li class="space-y-1">
            <h3 class="font-medium text-ink text-sm">{label}</h3>
            <p class="text-ink-subtle text-xs leading-relaxed">{body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
