---
import { getCollection } from 'astro:content';

// Hard publish gate — three conditions must all hold:
//   visible_public === true    (operator has consciously flipped the flag)
//   priority ∈ {P0, P1}        (noise filter)
//   status === 'approved'      (review gate)
// No env override. No preview bypass. Codified in the plan + gate docs.
const all = await getCollection('feature-proposals').catch(() => []);
const entries = all
  .filter(
    (e) =>
      e.data.visible_public === true &&
      ['P0', 'P1'].includes(e.data.priority) &&
      e.data.status === 'approved',
  )
  .sort((a, b) => b.data.captured_at.valueOf() - a.data.captured_at.valueOf())
  .slice(0, 5);

const hasEntries = entries.length > 0;
---

{
  hasEntries && (
    <section class="w-full px-6 md:px-12 lg:px-16 py-section">
      <div class="max-w-prose mx-auto">
        <h2 class="font-display font-semibold text-4xl mb-4 tracking-tight">What's new</h2>
        <p class="text-ink-muted text-2xl mb-10 max-w-narrow">
          Fresh AI features hookd already knows how to govern.
        </p>

        <ul class="divide-y divide-ink-subtle/20 border-y border-ink-subtle/20">
          {entries.map((entry) => (
            <li class="py-5 grid grid-cols-[auto_1fr] md:grid-cols-[7rem_1fr_auto] gap-4 md:gap-6 items-baseline">
              <span class="font-mono text-xs uppercase tracking-widest text-accent">
                {entry.data.engine}
              </span>
              <div class="space-y-1">
                <h3 class="font-medium text-ink">{entry.data.feature}</h3>
                <p class="text-sm text-ink-muted">{entry.data.implication}</p>
              </div>
              {entry.data.hookd_doc && (
                <a
                  href={entry.data.hookd_doc}
                  class="text-sm text-accent hover:underline md:justify-self-end"
                >
                  docs →
                </a>
              )}
            </li>
          ))}
        </ul>

        <p class="font-mono text-xs text-ink-subtle tracking-wide mt-6">
          Feed refreshed daily from the hookd intelligence pipeline.
        </p>
      </div>
    </section>
  )
}
