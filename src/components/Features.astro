---
const features = [
  {
    label: 'Pre-send blocking',
    body: 'Stop the request before it leaves the machine. Not "detect after the fact" — actually prevent the leak.',
  },
  {
    label: 'Vendor-neutral',
    body: 'Works with Claude, GPT, Gemini, Ollama, Cursor, Copilot. Change vendors without rewriting your policy.',
  },
  {
    label: 'Compliance-ready',
    body: 'Hooks for SOC 2, HIPAA, and GDPR workflows. DSAR gates. Scoped redaction by data classification.',
  },
  {
    label: 'Hash-chained audit',
    body: 'Tamper-evident log of every decision. Exportable. Indexable. Provable.',
  },
  {
    label: 'DSAR gates',
    body: 'Answer subject access requests with real data, not guesswork. Each prompt tied to the user and workspace that sent it.',
  },
  {
    label: 'Local-first',
    body: 'Classifier, logs, and policies live on the device or your own server. Nothing ships to a SaaS you did not vet.',
  },
];
---

<section class="w-full px-6 md:px-12 lg:px-16 py-section">
  <div class="max-w-prose mx-auto">
    <h2 class="font-display font-semibold text-4xl mb-12 tracking-tight">What it does</h2>
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        features.map(({ label, body }) => (
          <li class="bg-surface-raised rounded-lg p-6 space-y-2">
            <h3 class="font-medium text-ink">{label}</h3>
            <p class="text-ink-muted">{body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
