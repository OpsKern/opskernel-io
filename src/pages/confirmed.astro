---
import Base from '~/layouts/Base.astro';
---

<Base
  title="You're on the list — hookd"
  description="Your spot on the hookd waitlist is confirmed. We'll be in touch."
>
  <main id="main" class="w-full px-6 md:px-12 lg:px-16 py-section">
    <div class="max-w-prose mx-auto text-center space-y-6">
      <p class="font-mono text-sm text-ink-muted tracking-wide">hookd · from OpsKern</p>

      <h1 class="font-display font-bold text-4xl tracking-tight text-ink">You're on the list</h1>

      <p class="text-ink-muted text-lg">
        Your email is confirmed. We'll reach out when early access opens.
      </p>

      <p class="text-ink-subtle text-sm">
        Questions? Reply to your confirmation email or write to
        <a href="mailto:hello@opskernel.io" class="text-accent underline">hello@opskernel.io</a>.
      </p>

      <p class="font-mono text-xs text-ink-subtle tracking-wide pt-6">
        <a href="/" class="hover:text-accent">← hookd home</a>
      </p>
    </div>
  </main>
</Base>
