---
export interface Props {
  id?: string;
  variant?: 'hero' | 'footer';
}

const { id = 'waitlist', variant = 'hero' } = Astro.props;

// Buttondown: username 'hookd', sending domain newsletter.opskernel.io (DNS validated 2026-04-21).
// Turnstile site key: 0x4AAAAAADG7fb-PHmC0zWQF (secret key in Cloudflare Pages env: TURNSTILE_SECRET_KEY).
// Turnstile wiring deferred — requires a Pages Function proxy before it can validate server-side.
const BUTTONDOWN_USER = 'hookd';
const ACTIVE = true;
---

<form
  id={id}
  class:list={[
    'flex flex-col sm:flex-row gap-3 w-full',
    variant === 'hero' && 'max-w-narrow',
    variant === 'footer' && 'max-w-narrow',
  ]}
  action={ACTIVE
    ? `https://buttondown.com/api/emails/embed-subscribe/${BUTTONDOWN_USER}`
    : undefined}
  method="post"
  target="popupwindow"
  onsubmit={ACTIVE
    ? `window.open('https://buttondown.com/${BUTTONDOWN_USER}', 'popupwindow')`
    : 'return false'}
>
  <label for={`${id}-email`} class="sr-only">Email address</label>
  <input
    id={`${id}-email`}
    type="email"
    name="email"
    required
    autocomplete="email"
    placeholder="you@company.com"
    class="flex-1 bg-surface-raised text-ink placeholder:text-ink-subtle rounded-md px-4 py-3 border border-ink-subtle/40 focus:outline-none focus-visible:border-accent"
    disabled={!ACTIVE}
  />
  <button
    type="submit"
    class="bg-accent text-surface font-medium px-5 py-3 rounded-md hover:bg-accent-hover active:bg-accent-press transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
    disabled={!ACTIVE}
  >
    {ACTIVE ? 'Get early access' : 'Waitlist — opens soon'}
  </button>
</form>
{
  !ACTIVE && (
    <p class="text-ink-subtle text-sm mt-2">
      Waitlist opens after Buttondown DMARC + Turnstile (Phase A.1).
    </p>
  )
}
